---
import BaseLayout from "@/layouts/Layout.astro";
import ListPosts from "@/components/ListPosts.astro";
import { getPostsByTags, getTags } from "@/utils/posts";

export async function getStaticPaths() {
  const allTags = await getTags();

  return allTags.map((tag) => ({
    params: { tagSlug: tag.slug },
    props: { tag: tag.label },
  }));
}

const { tag } = Astro.props;
const posts = await getPostsByTags([tag]);
---

<BaseLayout title={`#${tag}`} description={`All posts tagged with "${tag}"`}>
  <h1><span>#</span>{tag}</h1>
  <ListPosts posts={posts} />
</BaseLayout>

<style>
  h1 {
    padding-block: 2rem 0;
  }
  span {
    font-size: var(--font-size-2);
    font-weight: bold;
    color: var(--tx-2);
  }
</style>
