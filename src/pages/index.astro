---
import { SITE } from "@/siteConfig";
import { getPostsByTags } from "@/utils/posts";

import Layout from "@/layouts/Layout.astro";
import ListPosts from "@/components/ListPosts.astro";

const writings = await getPostsByTags(["writings"]);
---

<Layout>
  <h1>{SITE.author}</h1>
  <div class="greeting">
    <strong class="emoticon">(⁠＾⁠∇⁠＾⁠)⁠ﾉ&nbsp&nbsp</strong>
    <i>hellooo kind human!!!</i>
    <br />wish you a great year of success!
  </div>

  <h2>Writings</h2>
  <ListPosts posts={writings} />
</Layout>

<style>
  h1 {
    display: none;
  }

  .greeting {
    text-align: center;
    margin-block: 3rem;
  }
</style>
