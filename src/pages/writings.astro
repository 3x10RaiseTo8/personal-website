---
import { getPostsByTags } from "@/utils/posts";

import Layout from "@/layouts/Layout.astro";
import ListPosts from "@/components/ListPosts.astro";

const writings = await getPostsByTags(["writings"]);
const title = "Writings";
---

<Layout title={title}>
  <h1>{title}</h1>
  <ListPosts posts={writings} />
</Layout>
