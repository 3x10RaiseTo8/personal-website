---
import { Font } from "astro:assets";

import { SITE } from "@/siteConfig";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string;
  author?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
}

const {
  title = SITE.title,
  author = SITE.author,
  description = SITE.description,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
} = Astro.props;

const ogImageURL = new URL(ogImage, Astro.url);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: ogImageURL,
  datePublished: pubDatetime?.toISOString(),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: [
    {
      "@type": "Person",
      name: author,
      url: SITE.website,
    },
  ],
};
---

<head>
  <!-- General Meta Tags -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Page specific Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <meta name="author" content={author} />
  {
    pubDatetime && (
      <meta
        property="article:published_time"
        content={pubDatetime.toISOString()}
      />
    )
  }
  {
    modDatetime && (
      <meta
        property="article:modified_time"
        content={modDatetime.toISOString()}
      />
    )
  }

  <!-- Open Graph / Facebook -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:url" content={canonicalURL} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImageURL} />
  <meta property="twitter:url" content={canonicalURL} />

  <!-- Links -->
  <link rel="canonical" href={canonicalURL} />
  <link
    rel="alternate"
    type="application/rss+xml"
    title={SITE.title}
    href={new URL("rss.xml", Astro.site)}
  />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link
    rel="icon"
    type="image/png"
    sizes="16x16"
    href="/favicon-thick-16.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href="/favicon-thick-32.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="48x48"
    href="/favicon-thick-48.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="64x64"
    href="/favicon-thick-64.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="128x128"
    href="/favicon-thick-128.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="180x180"
    href="/favicon-thick-180.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="192x192"
    href="/favicon-thick-192.png"
  />
  <link
    rel="icon"
    type="image/png"
    sizes="512x512"
    href="/favicon-thick-512.png"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="16x16"
    href="/favicon-thick-16.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="32x32"
    href="/favicon-thick-32.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="48x48"
    href="/favicon-thick-48.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="64x64"
    href="/favicon-thick-64.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="128x128"
    href="/favicon-thick-128.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="180x180"
    href="/favicon-thick-180.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="192x192"
    href="/favicon-thick-192.svg"
  />
  <link
    rel="icon"
    type="image/svg+xml"
    sizes="512x512"
    href="/favicon-thick-512.svg"
  />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-thick-180.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="mask-icon" href="/favicon-thick-16.svg" color="#000000" />
  <meta name="msapplication-TileColor" content="#000000" />
  <meta name="theme-color" content="#ffffff" />

  <meta
    name="theme-color"
    content="#FFFCF0"
    media="(prefers-color-scheme: light)"
  />
  <meta
    name="theme-color"
    content="#100F0F"
    media="(prefers-color-scheme: dark)"
  />

  <Font cssVariable="--font-sans" />
  <Font cssVariable="--font-serif-display" />
  <Font cssVariable="--font-fancy" />
  <Font cssVariable="--font-jp" />
  <Font cssVariable="--font-symbols" />
  <Font cssVariable="--font-symbols-2" />

  <ClientRouter />
</head>
