{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personal-website",
  "compatibility_date": "2026-05-18",
  "preview_urls": true,
  "workers_dev": true,
  "routes": [
    {
      "pattern": "abhishe.com",
      "custom_domain": true,
    },
  ],
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "drop-trailing-slash",
  },
}
