{
  "name": "personal-website",
  "type": "module",
  "version": "0.0.2",
  "scripts": {
    "dev": "astro dev --host",
    "stage": "astro dev -- --host --mode staging",
    "start": "astro dev",
    "prebuild": "git submodule update --init --recursive --remote",
    "about:prebuild": "echo 'Track remote changes for 'content' submodule'",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler deploy",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.5",
    "github-slugger": "^2.0.0",
    "mdx": "^0.3.1",
    "rehype-autolink-headings": "^7.1.0",
    "satori": "^0.26.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "wrangler": "^4.93.0"
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "vite-plugin-qrcode": "^0.4.1"
  },
  "overrides": {
    "vite": "^7"
  }
}
